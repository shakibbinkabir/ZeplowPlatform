# Logic site — local dev environment example
# Copy to `.env.local` and fill in.

# API base URL. Point to local Laravel API when running it; falls back to
# api.zeplow.com if unset.
NEXT_PUBLIC_API_URL=http://localhost:8000

# Site key — never change.
NEXT_PUBLIC_SITE_KEY=logic

# Force mock data (skip API calls entirely). Leave unset in production —
# client.ts already falls back to mock-data via try/catch if the API is
# unreachable. Set to 1 only for offline local dev.
NEXT_PUBLIC_ZEPLOW_MOCK_ONLY=0

# Cloudflare Turnstile site key (client-side, safe to expose).
# Leave blank in local dev — contact form renders without the widget.
NEXT_PUBLIC_CF_TURNSTILE_SITE_KEY=

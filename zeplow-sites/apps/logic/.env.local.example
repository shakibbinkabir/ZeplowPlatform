# Logic site — local dev environment example
# Copy to `.env.local` and fill in.

# API base URL. Point to local Laravel API when running it; falls back to
# api.zeplow.com if unset. Currently irrelevant — the build flag below forces
# offline mock data until the API ships.
NEXT_PUBLIC_API_URL=http://localhost:8000

# Site key — never change.
NEXT_PUBLIC_SITE_KEY=logic

# Force mock data (skip API calls entirely). Defaults to 1 in next.config.js
# until the production API is live; remove that hardcoded line and flip to 0
# here once api.zeplow.com responds.
NEXT_PUBLIC_ZEPLOW_MOCK_ONLY=1

# Cloudflare Turnstile site key (client-side, safe to expose).
# Leave blank in local dev — contact form renders without the widget.
NEXT_PUBLIC_CF_TURNSTILE_SITE_KEY=

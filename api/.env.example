APP_NAME="Zeplow API"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://api.zeplow.com

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error

DB_CONNECTION=mysql
DB_HOST=localhost
DB_PORT=3306
DB_DATABASE=api_zeplow
DB_USERNAME=api_user
DB_PASSWORD=

# API-only — no sessions, no views, no broadcasting
SESSION_DRIVER=array
SESSION_LIFETIME=120

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync

CACHE_STORE=file

MAIL_MAILER=smtp
MAIL_HOST=
MAIL_PORT=465
MAIL_USERNAME=hello@zeplow.com
MAIL_PASSWORD=
MAIL_ENCRYPTION=ssl
MAIL_FROM_ADDRESS=hello@zeplow.com
MAIL_FROM_NAME="Zeplow"

# Cloudflare Pages deploy hooks
CF_DEPLOY_HOOK_PARENT=
CF_DEPLOY_HOOK_NARRATIVE=
CF_DEPLOY_HOOK_LOGIC=

# Build agent token — generate with: openssl rand -hex 32
CF_BUILD_TOKEN=

# Cloudflare Turnstile (contact form bot protection)
CF_TURNSTILE_SECRET_KEY=
